#!/usr/bin/env python3
"""
毛毛AI - 全局配置
"""
from pathlib import Path

# ── 目录结构 ──────────────────────────────────────────────
BASE_DIR = Path(__file__).parent
RESULTS_DIR = BASE_DIR / "results"
MEMORY_DIR = BASE_DIR / "memory" / "store"
LOGS_DIR = BASE_DIR / "logs"

for _d in [RESULTS_DIR, MEMORY_DIR, LOGS_DIR]:
    _d.mkdir(parents=True, exist_ok=True)

# ── Tushare配置 ──────────────────────────────────────────
# 从加密配置加载Tushare Token
TUSHARE_TOKEN = ""
try:
    import sys
    sys.path.insert(0, str(Path.home() / ".openclaw" / "workspace"))
    from tushare_config import TushareConfig
    config = TushareConfig()
    TUSHARE_TOKEN = config.load_token()
    print(f"✅ 已加载Tushare Token (长度: {len(TUSHARE_TOKEN)})")
except Exception as e:
    print(f"⚠️ Tushare Token加载失败: {e}")

# 数据源优先级
DATA_SOURCES = ["tushare", "akshare"] if TUSHARE_TOKEN else ["akshare"]

# ── 资金监测权重 ──────────────────────────────────────────
SMART_MONEY_WEIGHTS = {
    "big_money": 0.35,  # 大单资金流
    "quant": 0.20,      # 量化行为特征
    "institution": 0.30, # 机构席位布局
    "sector": 0.15,     # 板块资金轮动
}

